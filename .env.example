OPENAI_API_KEY=sk-your-openai-api-key
# Optional:
# PORT=8000
# MASKING_ENABLED=true
# MASK_KEYWORDS=temporary-sensitive-term,emergency-redaction-term
# MASK_REPLACEMENT=[REDACTED]
# PII_PROVIDER=nemo
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:3002,http://127.0.0.1:3002

# NeMo GLiNER-PII preview:
# NVIDIA_API_KEY=nvapi-your-nvidia-api-key
# NEMO_PII_API_KEY=nvapi-your-nvidia-api-key
# NEMO_PII_SERVER_ENDPOINT=https://integrate.api.nvidia.com/v1/chat/completions
# NEMO_PII_MODEL=nvidia/gliner-pii
# NEMO_PII_CHUNK_LENGTH=384
# NEMO_PII_OVERLAP=128
# NEMO_PII_FLAT_NER=false

# OpenAI Guardrails PII uses local Presidio/spaCy via the openai-guardrails package.
# No OpenAI API key is required for this provider.
